{
  "git": {
    "requireCleanWorkingDir": true,
    "commit": true,
    "commitMessage": "chore(release): v${version}",
    "tag": true,
    "tagName": "v${version}",
    "push": true
  },
  "npm": {
    "publish": false
  },
  "github": {
    "release": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          {
            "type": "feat",
            "section": "Features"
          },
          {
            "type": "fix",
            "section": "Bug Fixes"
          },
          {
            "type": "perf",
            "section": "Performance"
          },
          {
            "type": "chore",
            "hidden": true
          }
        ]
      },
      "infile": "CHANGELOG.md"
    }
  },
  "hooks": {
    "before:init": "pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  }
}
